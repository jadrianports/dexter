# ─── Dexter environment template ───
# Copy this file to `.env` and fill in your values. `.env` is git-ignored — NEVER commit real secrets.
#
# Numeric ID vars (DEXTER_CHANNEL_ID / ERROR_LOG_CHANNEL_ID / OWNER_ID) may be left
# blank to disable that feature — config tolerates an empty value.
#
# Variable names are IDENTICAL in both environments (local .env and Koyeb secrets) — K-13.
# The only value that differs: DATABASE_URL (local Postgres vs Neon pooled string).

# ── REQUIRED — set as Koyeb encrypted Secrets in production (K-13) ──
# Discord Developer Portal → your app → Bot → Reset Token
DISCORD_TOKEN=
# Gemini API key (free): https://aistudio.google.com/apikey   (Phase 2 — /ask, /imagine, AI roasts)
GEMINI_API_KEY=
# Genius token: https://genius.com/api-clients → Client Access Token   (Phase 3 — /lyrics primary; falls back to AZLyrics if blank)
GENIUS_TOKEN=

# ── DATABASE ──
# LOCAL (docker-compose break-glass): docker-compose.yml injects the correct value automatically.
#   When running Postgres in Docker separately, adjust host/password as needed.
DATABASE_URL=postgresql://dexter:CHANGE_ME@postgres:5432/dexter
#
# KOYEB (production): paste the POOLED Neon connection string as a Koyeb encrypted Secret.
#   Neon console → Connection Details → select "Pooled connection" (host contains -pooler).
#   Example: postgresql://user:pass@ep-<id>-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
#   The bot strips the query string at startup (config.sanitize_database_url) — paste the raw string.
#   DATABASE_URL is the ONLY value that differs between local and Koyeb environments.

# Password for the 'dexter' Postgres user — used by the local docker-compose postgres service.
# Not needed in Koyeb (Neon manages its own credentials via DATABASE_URL).
POSTGRES_PASSWORD=CHANGE_ME

# ── MONITORING ──
# Bot-side outbound dead-man ping (K-09): create a free check at https://healthchecks.io,
# copy the ping URL here. The bot curls this URL at regular intervals; Healthchecks.io alerts
# if it stops. Blank = dead-man monitoring off.
# Note: UptimeRobot provides the INBOUND keep-alive ping (pings /health every 5 min to defeat
# Koyeb's 1-hour scale-to-zero) — that is configured in UptimeRobot, not here (docs/DEPLOY-KOYEB.md).
HEALTHCHECK_URL=https://hc-ping.com/your-uuid-here

# ── OPTIONAL — set as plain env vars in Koyeb (non-sensitive) ──
# Channel ID for unprompted posts (startup / idle / voice roasts). Blank = music/system-channel fallback.
DEXTER_CHANNEL_ID=
# Channel ID for error-log posts. Blank = Discord error logging off.
ERROR_LOG_CHANNEL_ID=
# Your Discord user ID — enables the owner-only /sync command.
OWNER_ID=
# IANA timezone for the streak day boundary. Blank = America/New_York.
STREAK_TIMEZONE=America/New_York
