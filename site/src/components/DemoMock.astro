---
// site/src/components/DemoMock.astro
//
// A reconstructed two-exchange Discord conversation. Honest because the words
// are (or will be) real, verbatim Dexter output — see demo-transcript.ts. While
// the real lines are still pending (PORT-02), resolveLine() shows the labeled
// preview sample so the component renders finished instead of leaking a token.
//
// The reveal is staged and plays ONCE when the mock scrolls into view (fixing
// the old always-looping CSS timeline that revealed everything in the first
// fraction of a 16s loop, then sat fully populated). Progressive enhancement:
// html.js hides the rows until an IntersectionObserver adds .is-playing;
// no-JS and reduced-motion visitors get the full static transcript.
import { demoTranscript, resolveLine } from "../data/demo-transcript";
import DemoMessage from "./DemoMessage.astro";

const [m1, m2, m3, m4] = demoTranscript;
const t1 = m1.text;
const t2 = resolveLine(m2);
const t3 = m3.text;
const t4 = resolveLine(m4);

const srTranscript =
  `${m1.handle}: ${t1}. Dexter replies: ${t2}. ` +
  `${m3.handle}: ${t3}. Dexter replies: ${t4}.`;
---

<section id="demo" class="section section--tint section--ruled" aria-labelledby="demo-heading">
  <div class="section-inner demo-inner">
    <div class="section-head demo-head">
      <p class="eyebrow">Live demo</p>
      <h2 id="demo-heading">Watch it work</h2>
      <p class="section-sub">
        A real exchange, reconstructed. It plays YouTube in voice — but the personality is the
        part people quote back.
      </p>
    </div>

    <div class="demo" role="img" aria-labelledby="demo-mock-label">
      <p id="demo-mock-label" class="sr-only">
        A Discord conversation demonstrating Dexter's personality: {srTranscript}
      </p>

      <div class="demo-frame" aria-hidden="true">
        <div class="demo-chrome">
          <span class="demo-channel">
            <span class="demo-channel-hash">#</span> general
          </span>
          <span class="demo-chrome-dots">
            <span></span><span></span><span></span>
          </span>
        </div>

        <div class="demo-messages">
          <DemoMessage speaker="human" handle={m1.handle} text={t1} timestamp="2:41 AM" delay="0.3s" />
          <DemoMessage speaker="dexter" text={t2} timestamp="2:41 AM" delay="1.4s" textDelay="2.3s" />
          <DemoMessage speaker="human" handle={m3.handle} text={t3} timestamp="2:52 AM" delay="3.3s" />
          <DemoMessage speaker="dexter" text={t4} timestamp="2:52 AM" delay="4.2s" textDelay="5.1s" />
        </div>
      </div>

      <p class="demo-caption text-label text-secondary">Real words. Reconstructed pixels.</p>
    </div>
  </div>
</section>

<script>
  // Play the staged reveal once, when the mock first scrolls into view.
  const demo = document.querySelector<HTMLElement>(".demo");
  if (demo) {
    const play = () => demo.classList.add("is-playing");
    if (!("IntersectionObserver" in window)) {
      play();
    } else {
      const io = new IntersectionObserver(
        (entries, obs) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              play();
              obs.disconnect();
            }
          }
        },
        { threshold: 0.4 },
      );
      io.observe(demo);
    }
  }
</script>
