---
// site/src/components/DemoMessage.astro
//
// One row in the demo mock. Markup only — all demo styling lives in global.css
// (.demo-*) so the staged-reveal gating (html.js .demo.is-playing ...) can span
// the DemoMock container and these child rows without cross-scope selector pain.
//
// Dexter rows carry a typing-indicator overlay that cross-fades into the text in
// the same bubble slot (no layout shift), driven purely by the two delay props.
interface Props {
  speaker: "human" | "dexter";
  handle?: string;
  text: string;
  timestamp?: string;
  delay: string; // row reveal, e.g. "0.3s"
  textDelay?: string; // dexter only: when the text crossfades in over the typing dots
}

const { speaker, handle, text, timestamp = "2:41 AM", delay, textDelay = "0s" } = Astro.props;
const isDexter = speaker === "dexter";
const username = isDexter ? "dexter" : (handle ?? "wrenlow");
const initial = username.charAt(0).toUpperCase();
---

<div
  class={`demo-message demo-anim ${isDexter ? "demo-message--dexter" : "demo-message--human"}`}
  style={`--delay:${delay}; --text-delay:${textDelay};`}
>
  <div class={`demo-avatar ${isDexter ? "demo-avatar--dexter" : "demo-avatar--human"}`} aria-hidden="true">
    {initial}
  </div>
  <div class="demo-message-body">
    <p class="demo-message-meta">
      <span class="demo-username">{username}</span>
      {isDexter && <span class="demo-bot-pill">APP</span>}
      <span class="demo-timestamp">{timestamp}</span>
    </p>
    <div class="demo-bubble">
      {
        isDexter && (
          <span class="demo-typing-inline" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        )
      }
      <p class="demo-message-text">{text}</p>
    </div>
  </div>
</div>
