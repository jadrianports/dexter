---
// site/src/components/Footer.astro
//
// Minimal footer line: a wordmark, attribution, and two repo links.
---

<footer class="site-footer">
  <div class="section-inner footer-inner">
    <p class="footer-mark">
      dexter<span class="footer-cursor" aria-hidden="true">_</span>
    </p>
    <p class="footer-meta text-label text-secondary">
      Built by jadrianports ·
      <a href="https://github.com/jadrianports/dexter" rel="noopener noreferrer">GitHub ↗</a>
      ·
      <a
        href="https://github.com/jadrianports/dexter/blob/main/README.md"
        rel="noopener noreferrer">README ↗</a
      >
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-xl) var(--gutter);
    background-color: var(--color-bg-tint);
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .footer-mark {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .footer-cursor {
    color: var(--color-accent);
  }

  .footer-meta {
    margin: 0;
  }

  .footer-meta a {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .footer-meta a:hover {
    color: var(--color-accent);
  }
</style>
