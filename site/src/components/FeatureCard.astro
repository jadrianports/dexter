---
// site/src/components/FeatureCard.astro
//
// One feature card: h3 title + body blurb. Copy is used verbatim from
// 23-UI-SPEC.md's Copywriting Contract -- see Features.astro for the data.
// `bodyHtml` may contain inline <code> spans (verbatim slash-command
// mentions) -- set:html is used only for that static, hand-authored markup,
// the same pattern already established by Hero.astro/Cta.astro's CTA anchors.
interface Props {
  title: string;
  bodyHtml: string;
}

const { title, bodyHtml } = Astro.props;
---

<div class="feature-card">
  <h3>{title}</h3>
  <p set:html={bodyHtml} />
</div>

<style>
  .feature-card {
    background-color: var(--color-surface);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  @media (min-width: 1024px) {
    .feature-card {
      padding: var(--space-lg);
    }
  }

  .feature-card h3 {
    margin: 0;
  }

  .feature-card p {
    font-family: var(--font-sans);
    font-size: var(--text-body-size);
    line-height: var(--text-body-line-height);
    color: var(--color-text);
    margin: 0;
  }

  .feature-card p :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background-color: var(--color-bg);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0 var(--space-xs);
  }
</style>
