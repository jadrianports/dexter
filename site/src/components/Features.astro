---
// site/src/components/Features.astro
//
// PORT-01: the six-feature showcase. Each card carries a technical facet tag
// (playback / gemini / controls / pgvector / ambient / vision) — a meaningful
// label, not arbitrary numbering. Feature 3 deliberately names the gap the demo
// can't show (the five-button panel); do not soften or drop that sentence.
import FeatureCard from "./FeatureCard.astro";

const features = [
  {
    tag: "playback",
    title: "Full YouTube playback",
    bodyHtml:
      "Queues, skips, seeks, loops, and a genuinely unnecessary number of audio filters. Bassboost included, regret not included.",
  },
  {
    tag: "gemini",
    title: "An AI with opinions",
    bodyHtml:
      "<code>/ask</code> and <code>/roast</code> are grounded in what you've actually listened to — Gemini, wired to real play history. It remembers, so it can hold it against you.",
  },
  {
    tag: "controls",
    title: "A five-button now-playing panel",
    bodyHtml:
      "Play/pause, skip, loop, shuffle, and stop, live on the embed. The demo above can't show it — this is the part you're missing.",
  },
  {
    tag: "pgvector",
    title: "Long-term memory",
    bodyHtml:
      "pgvector-backed recall surfaces old habits at the worst possible moments — and <code>/memory forget</code> deletes it all, verbatim, on request.",
  },
  {
    tag: "ambient",
    title: "Unprompted personality",
    bodyHtml:
      "Reacts to voice joins, late-night sessions, and repeat plays without being asked. It has opinions about your 3am queue.",
  },
  {
    tag: "vision",
    title: "Vision roasts",
    bodyHtml:
      "Post a picture in the wrong channel and Gemini's vision model might have a comment. Safety-gated, mercifully rare.",
  },
];
---

<section id="features" class="section" aria-labelledby="features-heading">
  <div class="section-inner">
    <div class="section-head">
      <p class="eyebrow">Capabilities</p>
      <h2 id="features-heading">What it actually does</h2>
      <p class="section-sub">
        Six things it does well, and one it wants you to know it can't show off in a screenshot.
      </p>
    </div>

    <div class="feature-grid">
      {features.map((f) => <FeatureCard tag={f.tag} title={f.title} bodyHtml={f.bodyHtml} />)}
    </div>
  </div>
</section>

<style>
  .feature-grid {
    margin-top: var(--space-2xl);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1000px) {
    .feature-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
