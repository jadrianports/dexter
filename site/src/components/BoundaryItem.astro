---
// site/src/components/BoundaryItem.astro
//
// One PORT-04 boundary as a spec-sheet row: a left rail (facet tag + label +
// optional offline status) and a body in the constraint -> deliberate decision
// shape (D-10). Calmer ember hue, not the amber CTA accent — disclosure is not
// a call to action. Voice: NOT sarcastic (CLAUDE.md Critical Rule 6).
//
// `bodyHtml` may contain <code> (slash commands) and <strong> (the one
// emphasized clause in the hosting boundary) — mechanical markup of verbatim
// copy, not new wording.
interface Props {
  tag: string;
  label: string;
  bodyHtml: string;
  showOfflineDot?: boolean;
}

const { tag, label, bodyHtml, showOfflineDot = false } = Astro.props;
---

<article class="boundary-item">
  <div class="boundary-rail">
    <span class="boundary-tag">
      <span class="boundary-marker" aria-hidden="true"></span>
      {tag}
    </span>
    <h3 class="boundary-label">{label}</h3>
    {
      showOfflineDot && (
        <span class="offline-indicator">
          <span class="offline-dot" aria-hidden="true" />
          Offline
        </span>
      )
    }
  </div>
  <p class="boundary-body" set:html={bodyHtml} />
</article>

<style>
  .boundary-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  @media (min-width: 720px) {
    .boundary-item {
      grid-template-columns: 220px 1fr;
      gap: var(--space-2xl);
      padding: var(--space-xl);
    }
  }

  .boundary-rail {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .boundary-tag {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ember);
  }

  .boundary-marker {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background-color: var(--color-ember);
  }

  .boundary-label {
    color: var(--color-text);
    margin: 0;
  }

  .offline-indicator {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--color-text-secondary);
  }

  .offline-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--color-ember);
  }

  .boundary-body {
    font-family: var(--font-sans);
    font-size: var(--text-body-sm);
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .boundary-body :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }
</style>
