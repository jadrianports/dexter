---
// site/src/components/Boundaries.astro
//
// PORT-04 / D-10: four boundaries, each framed constraint -> deliberate
// decision. Single-column, full-width, read one at a time. Positioned right
// before the closing CTA so a visitor reads "offline unless the owner is
// running it" before clicking Add-to-Discord.
//
// Voice: deliberately NOT sarcastic anywhere here (CLAUDE.md Critical Rule 6).
// This is the honest, straight-read section — proper case, no amber CTA energy.
import BoundaryItem from "./BoundaryItem.astro";

const boundaries = [
  {
    tag: "Scale",
    label: "Verification wall",
    bodyHtml:
      "Discord requires verification and privileged-intent approval past 100 servers — a process this project hasn't pursued. The target scale is modest (single-digit to low-dozens of servers), so verification was scoped out rather than pursued for a portfolio deployment.",
    showOfflineDot: false,
  },
  {
    tag: "Hosting",
    label: "On-demand hosting",
    bodyHtml:
      "Dexter runs on the owner's residential PC, not an always-on host — the free-tier cloud options that exist all get blocked by YouTube's datacenter-IP rules. Hosting stays on-demand rather than forcing a workaround. <strong>The bot is offline unless the owner is currently running it</strong> — invite it, and don't expect it online 24/7 yet.",
    showOfflineDot: true,
  },
  {
    tag: "Personality",
    label: "Full-savage + kill-switch",
    bodyHtml:
      "Dexter's sarcasm runs at full intensity in every server — there's no per-guild tone dial. Rather than build a settings surface for something core to the bot's identity, the owner gets a real, fast kill-switch instead: list every server Dexter is in, silence one instantly, or force it to leave and blacklist a re-invite — two enforced choke points, not a scattered set of per-command checks.",
    showOfflineDot: false,
  },
  {
    tag: "Privacy",
    label: "Hybrid memory scoping",
    bodyHtml:
      "Dexter remembers things about users via a vector-search long-term memory store. <code>/roast @user</code>, ambient roasts, and proactive callbacks only recall memories scoped to the current server — a third party's history never crosses servers. <code>/ask</code> stays global, but only for your own memory (self-recall, no cross-user exposure is possible). When Dexter leaves a server, that server's data — config, queues, jams, and its scoped memories — is purged.",
    showOfflineDot: false,
  },
];
---

<section id="boundaries" class="section section--tint section--ruled" aria-labelledby="boundaries-heading">
  <div class="section-inner">
    <div class="section-head">
      <p class="eyebrow eyebrow--ember">The fine print</p>
      <h2 id="boundaries-heading">Known limits</h2>
      <p class="section-sub">Four deliberate tradeoffs, disclosed here instead of discovered later.</p>
    </div>

    <div class="boundary-list">
      {
        boundaries.map((b) => (
          <BoundaryItem
            tag={b.tag}
            label={b.label}
            bodyHtml={b.bodyHtml}
            showOfflineDot={b.showOfflineDot}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .eyebrow--ember {
    color: var(--color-ember);
  }

  .boundary-list {
    margin-top: var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
</style>
