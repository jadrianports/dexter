---
// site/src/components/Cta.astro
//
// The closing section: a contained panel with the second CTA (identical label
// to CTA #1 so the two read as the same action, not two offers — D-05) and the
// "browse the code" link. The invite anchor is injected via set:html so Astro
// never entity-escapes the URL — the same drift-guard-safe pattern as Hero.
import { INVITE_URL } from "../config";

const ctaHtml = `<a href="${INVITE_URL}" class="cta-button">Add to Discord</a>`;
---

<section id="cta" class="section" aria-labelledby="cta-heading">
  <div class="section-inner">
    <div class="cta-panel">
      <p class="eyebrow">Ready when you are</p>
      <h2 id="cta-heading">Add it. See what happens.</h2>
      <p class="cta-body">
        One click, ten permissions, zero admin rights. Dexter joins, waits for <code>/setup</code>,
        and stays quiet until you tell it otherwise.
      </p>
      <div class="cta-actions">
        <Fragment set:html={ctaHtml} />
        <a href="https://github.com/jadrianports/dexter" class="ghost-link">Browse the code ↗</a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(120% 140% at 100% 0%, rgba(255, 180, 84, 0.14), transparent 55%),
      linear-gradient(180deg, var(--color-surface-2), var(--color-surface));
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .cta-panel {
      padding: var(--space-3xl);
    }
  }

  .cta-body {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    line-height: 1.65;
    color: var(--color-text-secondary);
    max-width: 40em;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  @media (max-width: 479px) {
    .cta-actions {
      width: 100%;
    }
    .cta-actions :global(.ghost-link) {
      width: 100%;
    }
  }
</style>
