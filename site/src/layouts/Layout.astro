---
// Minimal shell for plan 23-03. The full head (OG tags, font preloads,
// global.css) and the skip-link land in plan 23-05 — this only needs to be
// enough for a real build so plan 23-03's drift guard has something to scan.
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <main id="main-content">
      <slot />
    </main>
  </body>
</html>
